FLASK_ENV=development
FLASK_APP=wsgi.py
SECRET_KEY=change-this-to-a-long-random-string

# Database
DATABASE_URL=postgresql://mamarise_user:password@localhost:5432/mamarise_db

# JWT
JWT_SECRET_KEY=change-this-to-a-different-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://mamarise-frontend.vercel.app

# Rate limiting storage (use redis:// in production, memory:// for local dev)
RATELIMIT_STORAGE_URI=memory://

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15